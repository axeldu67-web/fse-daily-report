{
  "buildCommand": "ls",
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/payment", "destination": "/payment.html" }
  ]
}
